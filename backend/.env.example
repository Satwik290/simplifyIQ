# SimplifIQ Lead Automation System - Backend Environment Config

# Server Configuration
PORT=3001
NODE_ENV=development

# Gemini API (Google AI Studio) - Required for AI Analysis
# Get a free key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Email Delivery Configuration (Nodemailer SMTP or SendGrid)
# Set EMAIL_PROVIDER to 'nodemailer' for SMTP (free, highly recommended for testing) or 'sendgrid'
EMAIL_PROVIDER=nodemailer
EMAIL_FROM=audits@simplif-iq.com
EMAIL_FROM_NAME="SimplifIQ Business Audits"

# SMTP Settings (Required if EMAIL_PROVIDER=nodemailer)
# For testing locally, you can use a free Mailtrap account (https://mailtrap.io) or custom Gmail SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# SendGrid Settings (Required if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# Google Sheets Logging (Optional - P1 Bonus)
# Spreadsheet ID where lead logs will be appended
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google Drive Archiving (Optional - P1 Bonus)
# Folder ID where generated PDF reports will be uploaded
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Service Account Credentials (Optional - P1 Bonus)
# Minified JSON credentials string of your Google Cloud Service Account
# Format: {"type": "service_account", "project_id": ...}
GOOGLE_SERVICE_ACCOUNT_JSON=
