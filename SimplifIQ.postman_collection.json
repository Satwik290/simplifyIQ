        {
          "name": "2. Poll Finance Lead Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/leads/{{financeLeadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
