          "name": "1. Submit Finance Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('financeLeadId', jsonData.leadId);",
                  "pm.test('Lead submitted successfully', function () {",
                  "    pm.expect(jsonData.success).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
