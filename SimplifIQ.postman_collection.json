            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Goldman Investment Partners\",\n  \"website\": \"goldman-invest.com\",\n  \"industry\": \"Finance & Fintech\",\n  \"contactName\": \"Sarah Johnson\",\n  \"email\": \"sarah@goldman-invest.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
